{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "URL Kisaltici Servisi - Backend Staj Projesi",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node scripts/migrate.js",
    "test": "jest --runInBand"
